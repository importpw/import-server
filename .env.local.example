# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in values.
# ---------------------------------------------------------------------------

# Symmetric key used to encrypt + authenticate the session cookie. Rotate
# this to invalidate all existing sessions. Generate with:
#
#   openssl rand -hex 32
#
# Required.
AUTH_SECRET=

# ---------------------------------------------------------------------------
# GitHub OAuth
# ---------------------------------------------------------------------------
# Register an OAuth app at https://github.com/settings/developers and set
# the callback URL to http(s)://<your-host>/api/auth/callback.
#
# Optional, but required for the "Sign in with GitHub" flow. Without these
# set, the site works anonymously (subject to the unauthenticated 60/hr
# rate limit, unless GITHUB_TOKEN below is also set).
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Anonymous fallback token
# ---------------------------------------------------------------------------
# Used on behalf of unauthenticated visitors so the unauthenticated
# 60/hour rate limit doesn't cripple the site for logged-out users.
# Logged-in users' own OAuth tokens take precedence over this value.
#
# A classic PAT with `public_repo` (or a fine-grained token with read
# access to public repos) is sufficient. Optional.
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# Vercel Sandbox (powers /api/exec)
# ---------------------------------------------------------------------------
# The "Run this code" popup on the landing page runs user-supplied shell
# scripts inside a Vercel Sandbox microVM for isolation (see
# app/api/exec/route.ts). In production on Vercel this works automatically
# — VERCEL_OIDC_TOKEN is injected for you.
#
# For local dev you need to pull a dev OIDC token from the linked project:
#
#   vercel link
#   vercel env pull
#
# That will write VERCEL_OIDC_TOKEN into .env.local. It's scoped to the
# project and expires every 12 hours; re-run `vercel env pull` when it
# stops working.
VERCEL_OIDC_TOKEN=

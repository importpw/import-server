# Copy this file to `.env.local` and fill in a GitHub personal access token.
#
# Unauthenticated GitHub API requests are rate-limited to 60/hour per IP.
# Set this in local development to raise the limit to 5000/hour (and to
# access private repos). The token only needs `public_repo` scope.
#
# Create one at: https://github.com/settings/tokens?type=beta
# (Fine-grained) or https://github.com/settings/tokens/new (classic).
GITHUB_TOKEN=
